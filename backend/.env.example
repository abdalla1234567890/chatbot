# Backend environment variables (example)
# Copy to `.env` and fill values. Do NOT commit real secrets.

ENVIRONMENT=development

# Security
JWT_SECRET_KEY=change_me_to_a_long_random_value
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# AI
GEMINI_API_KEY=

# Google Sheets (JSON string or Base64-encoded JSON)
GOOGLE_CREDENTIALS_JSON=
GOOGLE_SHEET_NAME=الشات والتصنيفات

# CORS (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000

# Bootstrap admin (first run when DB is empty)
ADMIN_BOOTSTRAP_CODE=change_me

